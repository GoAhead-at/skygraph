    "spdlog",
    "nlohmann-json",
    "zlib",
    "rapidcsv",
    {
      "name": "imgui",
      "features": [
        "docking-experimental",
        "dx11-binding",
        "win32-binding"
      ]
    },
    "implot"
  ]
}
